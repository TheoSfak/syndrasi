<IfModule mod_rewrite.c>
    RewriteEngine On

    # Serve existing files/directories directly (assets, manifest, service worker)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Everything else goes to the front controller
    RewriteRule ^ index.php [L]
</IfModule>

# Basic hardening
Options -Indexes
<FilesMatch "\.(env|ini|log|sql)$">
    Require all denied
</FilesMatch>
