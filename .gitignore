# Dependencies
/vendor/
/node_modules/

# Runtime / generated
/storage/logs/*
/storage/exports/*
/storage/uploads/*
!/storage/logs/.gitkeep
!/storage/exports/.gitkeep
!/storage/uploads/.gitkeep

# Local config with secrets (commit *.example instead if needed)
config/local.php
.env
.env.*

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/

# Build / working artifacts
*.fix.php
*.fix.js
*.swap.php
*.new.md
*.new
*.bak
*.orig

# Local pre-edit backups (safety snapshots, never committed)
/_backups/
_backups/
